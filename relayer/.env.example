# --- Pi Network (deposit watcher + redemption release) ---
PI_HORIZON_URL=https://api.testnet.minepi.com
PI_NETWORK_PASSPHRASE="Pi Testnet"
PI_BRIDGE_DEPOSIT_ADDRESS=
PI_BRIDGE_CUSTODIAN_SECRET_KEY=
# Ledgers of depth required before a deposit is minted. See README.md#confirmation-depth-policy.
PI_CONFIRMATION_DEPTH=30
PI_POLL_INTERVAL_MS=5000

# --- Stellar (wPi contract) ---
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
WPI_CONTRACT_ID=
BRIDGE_STELLAR_ADMIN_SECRET_KEY=
STELLAR_POLL_INTERVAL_MS=5000

# --- Relayer ---
RELAYER_STORE_PATH=./data/relayer-state.json
# When true, logs intended mints/releases instead of submitting them.
DRY_RUN=false
